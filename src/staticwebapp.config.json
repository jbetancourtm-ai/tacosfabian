{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/admin.html",
      "/assets/*",
      "/api/*",
      "/*.css",
      "/*.js",
      "/favicon.ico"
    ]
  },
  "routes": [
    {
      "route": "/admin",
      "rewrite": "/admin.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    },
    "403": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    }
  }
}